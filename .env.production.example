# ============================================
# BookTracker - Production Environment Template
# ============================================
# IMPORTANT: Copiez ce fichier en .env.production
# et remplissez avec vos valeurs réelles
# Ne commitez JAMAIS le fichier .env.production!

# JWT Configuration
# Générez avec: openssl rand -base64 64
JWT_SECRET=CHANGE-THIS-TO-A-SECURE-RANDOM-STRING-MINIMUM-256-BITS-FOR-PRODUCTION

# Database Passwords
# Générez avec: openssl rand -base64 32
AUTH_DB_PASSWORD=CHANGE_THIS_AUTH_PASSWORD
BOOK_DB_PASSWORD=CHANGE_THIS_BOOK_PASSWORD
TRACKER_DB_PASSWORD=CHANGE_THIS_TRACKER_PASSWORD
RECO_DB_PASSWORD=CHANGE_THIS_RECO_PASSWORD

# Google Books API (Optional - pour enrichir les données des livres)
# Obtenir une clé sur: https://console.cloud.google.com/
GOOGLE_BOOKS_API_KEY=

# Domain Configuration
DOMAIN=nacer-dev.me
FRONTEND_URL=https://nacer-dev.me
API_URL=https://nacer-dev.me/api

# Email Configuration (si vous voulez ajouter la fonctionnalité d'email)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=votre-email@gmail.com
# SMTP_PASSWORD=votre-mot-de-passe-application
# EMAIL_FROM=noreply@nacer-dev.me
